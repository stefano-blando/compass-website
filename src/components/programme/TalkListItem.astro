---
import type { Locale, Talk } from '../../data/types';
import { buildLocalizedPath, getSpeakerBySlug } from '../../lib/site';

interface Props {
  locale: Locale;
  talk: Talk;
}

const { locale, talk } = Astro.props;
const speakers = talk.speakerSlugs
  .map((speakerSlug) => getSpeakerBySlug(speakerSlug))
  .filter((speaker): speaker is NonNullable<typeof speaker> => Boolean(speaker));
const titleMatchesSingleSpeaker =
  speakers.length === 1 && talk.title[locale].trim().toLowerCase() === speakers[0].name.trim().toLowerCase();
const speakerLine = titleMatchesSingleSpeaker
  ? speakers.map((speaker) => speaker.affiliation).join(' / ')
  : speakers.map((speaker) => `${speaker.name} · ${speaker.affiliation}`).join(' / ');
const startsAt = talk.startsAt?.slice(11, 16);
---

<li class="talk-item">
  <a class="talk-item__link" href={buildLocalizedPath(locale, `talks/${talk.slug}`)}>
    {startsAt && <span class="talk-item__time">{startsAt}</span>}
    <span class="talk-item__content">
      <strong>{talk.title[locale]}</strong>
      {speakerLine && <span>{speakerLine}</span>}
    </span>
  </a>
</li>

<style>
  .talk-item {
    list-style: none;
  }

  .talk-item__link {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.95rem;
    align-items: start;
    padding: 1rem 1.1rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(20, 32, 51, 0.08);
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .talk-item__link:hover {
    transform: translateY(-2px);
    border-color: rgba(126, 36, 52, 0.2);
    box-shadow: 0 16px 32px rgba(20, 32, 51, 0.08);
  }

  .talk-item__time {
    min-width: 3.2rem;
    padding-top: 0.1rem;
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .talk-item__content {
    display: grid;
    gap: 0.2rem;
  }

  .talk-item__content strong {
    font-size: 1.18rem;
    line-height: 1.1;
  }

  .talk-item__content span {
    color: var(--ink-soft);
    font-size: 0.96rem;
  }

  @media (max-width: 720px) {
    .talk-item__link {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .talk-item__time {
      min-width: 0;
    }
  }
</style>
