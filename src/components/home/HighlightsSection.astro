---
import type { Locale } from '../../data/types';
import { getHomepageHighlights } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const highlights = getHomepageHighlights(locale);
---

<section class="home-highlights" data-home-reveal>
  <div class="container home-highlights__grid">
    {highlights.map((highlight, index) => (
      <article class="home-highlights__card" style={`--reveal-delay: ${index * 70}ms;`}>
        <p class="home-highlights__value">{highlight.value}</p>
        <p class="home-highlights__label">{highlight.label}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .home-highlights {
    padding: 0.4rem 0 2rem;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 520ms ease,
      transform 520ms ease;
  }

  .home-highlights.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home-highlights__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .home-highlights__card {
    border-radius: 24px;
    padding: 1.4rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.62);
    background:
      linear-gradient(180deg, rgba(55, 95, 138, 0.1), rgba(255, 255, 255, 0)),
      var(--surface-strong);
    box-shadow: var(--shadow);
    text-align: center;
  }

  .home-highlights__value {
    margin: 0;
    color: var(--accent);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.9;
    font-weight: 800;
  }

  .home-highlights__label {
    margin: 0.4rem 0 0;
    color: var(--ink-soft);
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .home-highlights__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-highlights__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
