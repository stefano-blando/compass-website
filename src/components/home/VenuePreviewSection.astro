---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent, getLabels, siteConfig } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { venue } = getHomepageContent(locale);
---

<section id="venue-preview" class="venue-preview" data-home-reveal>
  <div class="venue-preview__stage">
    <div class="container venue-preview__layout">
      <div class="venue-preview__copy">
        <p class="section-kicker">{venue.eyebrow}</p>
        <h2>{venue.title}</h2>
        <p>{venue.intro}</p>

        <div class="venue-preview__facts">
          {venue.facts.map((fact, index) => (
            <article class="venue-preview__fact" style={`--reveal-delay: ${index * 80}ms;`}>
              <span>0{index + 1}</span>
              <p>{fact}</p>
            </article>
          ))}
        </div>
      </div>

      <aside class="venue-preview__card">
        <p class="venue-preview__card-label">{labels.venue}</p>
        <h3>{siteConfig.venue}</h3>
        <p class="venue-preview__date">{siteConfig.eventDate}</p>
        <p class="venue-preview__travel-title">{venue.travelTitle}</p>
        <p>{venue.travelBody}</p>
        <a class="btn-secondary" href={buildLocalizedPath(locale, 'venue')}>{labels.venue}</a>
      </aside>
    </div>
  </div>
</section>

<style>
  .venue-preview {
    padding: 1.2rem 0 2rem;
    opacity: 0;
    transform: translateY(26px);
    transition:
      opacity 520ms ease,
      transform 520ms ease;
  }

  .venue-preview.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .venue-preview__stage {
    position: relative;
    width: min(1240px, 96%);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 2.8rem) 0;
    border-radius: 38px;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgba(55, 95, 138, 0.34), transparent 32%),
      linear-gradient(135deg, rgba(126, 36, 52, 0.88), rgba(20, 32, 51, 0.92));
    box-shadow: var(--shadow-strong);
  }

  .venue-preview__stage::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 42px 42px;
    opacity: 0.18;
    pointer-events: none;
  }

  .venue-preview__layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1rem;
    align-items: center;
  }

  .venue-preview__copy,
  .venue-preview__card {
    color: #f8f4ef;
  }

  .venue-preview__copy h2 {
    margin: 0.3rem 0 0.8rem;
    font-size: clamp(2.5rem, 5vw, 4.3rem);
    line-height: 0.93;
    max-width: 11ch;
  }

  .venue-preview__copy p {
    max-width: 42rem;
    color: rgba(248, 244, 239, 0.84);
  }

  .venue-preview__facts {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .venue-preview__fact {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .venue-preview__fact span {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  .venue-preview__fact p {
    margin: 0;
  }

  .venue-preview__card {
    border-radius: 28px;
    padding: 1.4rem;
    background: rgba(255, 253, 249, 0.9);
    color: var(--ink);
    box-shadow: 0 22px 46px rgba(5, 10, 16, 0.22);
  }

  .venue-preview__card-label,
  .venue-preview__travel-title {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .venue-preview__card h3 {
    margin: 0.45rem 0 0;
    font-size: 2.25rem;
    line-height: 0.95;
  }

  .venue-preview__date {
    margin: 0.45rem 0 1rem;
    color: var(--ink-soft);
    font-weight: 700;
  }

  .venue-preview__travel-title {
    margin-top: 0.95rem;
  }

  .venue-preview__card .btn-secondary {
    margin-top: 1rem;
  }

  @media (max-width: 980px) {
    .venue-preview__layout {
      grid-template-columns: 1fr;
    }
  }
</style>
