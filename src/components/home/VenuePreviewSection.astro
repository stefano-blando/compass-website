---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent, getLabels, siteConfig } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { venue } = getHomepageContent(locale);
const venueRouteEyebrow = locale === 'it' ? 'Apri la pagina sede' : 'Open venue page';
const venueVisualLabel = locale === 'it' ? 'Visual della sede Sant’Anna' : 'Sant’Anna venue visual';
const slides = [
  {
    title: venueVisualLabel,
    body: venue.facts[0],
  },
  {
    title: locale === 'it' ? 'Aula 3 placeholder' : 'Aula 3 placeholder',
    body: venue.facts[1],
  },
  {
    title: locale === 'it' ? 'Pisa context placeholder' : 'Pisa context placeholder',
    body: venue.travelBody,
  },
];
---

<section id="venue-preview" class="venue-preview" data-home-reveal>
  <div class="venue-preview__carousel" data-venue-carousel>
    <div class="venue-preview__slides">
      {slides.map((slide, index) => (
        <figure
          class:list={[
            'venue-preview__slide',
            'venue-preview__visual-shell',
            `venue-preview__slide--${index + 1}`,
            index === 0 && 'is-active',
          ]}
          aria-hidden={index === 0 ? 'false' : 'true'}
        >
          <div class="venue-preview__slide-overlay">
            <span class="venue-preview__route-line venue-preview__route-line--a"></span>
            <span class="venue-preview__route-line venue-preview__route-line--b"></span>
            <span class="venue-preview__slide-label">{slide.title}</span>
            <p>{slide.body}</p>
          </div>
        </figure>
      ))}
    </div>

    <aside class="venue-preview__card" data-reveal-item data-scroll-shift data-scroll-speed="14" data-scroll-direction="-1">
      <p class="venue-preview__card-label">{venue.eyebrow}</p>
      <h2>{siteConfig.venue}</h2>
      <p class="venue-preview__date">{siteConfig.eventDate}</p>
      <p class="venue-preview__copy">{venue.intro}</p>

      <div class="venue-preview__facts">
        {venue.facts.map((fact, index) => (
          <article class="venue-preview__fact" style={`--reveal-delay: ${index * 80 + 70}ms;`} data-reveal-item>
            <span>0{index + 1}</span>
            <p>{fact}</p>
          </article>
        ))}
      </div>

      <a class="maps-link venue-preview__maps-link" href={buildLocalizedPath(locale, 'venue')}>
        {venueRouteEyebrow} →
      </a>
    </aside>

    <div class="venue-preview__dots" role="tablist" aria-label={labels.venue}>
      {slides.map((_, index) => (
        <button class:list={['venue-preview__dot', index === 0 && 'is-active']} type="button" aria-label={`${labels.venue} ${index + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-venue-carousel]');
    if (!root) {
      return;
    }

    const slides = Array.from(root.querySelectorAll('.venue-preview__slide'));
    const dots = Array.from(root.querySelectorAll('.venue-preview__dot'));
    if (!slides.length || !dots.length) {
      return;
    }

    let current = 0;
    let timer;

    const apply = (index) => {
      slides.forEach((slide, slideIndex) => {
        const active = slideIndex === index;
        slide.classList.toggle('is-active', active);
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
      });

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle('is-active', dotIndex === index);
      });

      current = index;
    };

    const next = () => {
      apply((current + 1) % slides.length);
    };

    const start = () => {
      stop();
      timer = window.setInterval(next, 4200);
    };

    const stop = () => {
      if (timer) {
        window.clearInterval(timer);
      }
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        apply(index);
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    start();
  })();
</script>

<style>
  .venue-preview {
    padding: 0;
    background: #e9e6e2;
  }

  .venue-preview__carousel {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: min(92vh, 880px);
    overflow: hidden;
    background: #162433;
  }

  .venue-preview__slides {
    position: absolute;
    inset: 0;
  }

  .venue-preview__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 900ms ease, transform 5200ms ease;
    background-size: cover;
    background-position: center;
  }

  .venue-preview__slide.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .venue-preview__slide--1 {
    background:
      linear-gradient(180deg, rgba(10, 18, 27, 0.3), rgba(10, 18, 27, 0.1)),
      linear-gradient(135deg, #405268, #223445 56%, #162433);
  }

  .venue-preview__slide--2 {
    background:
      linear-gradient(180deg, rgba(10, 18, 27, 0.24), rgba(10, 18, 27, 0.12)),
      linear-gradient(135deg, #73514f, #b78d7e 52%, #4a3035);
  }

  .venue-preview__slide--3 {
    background:
      linear-gradient(180deg, rgba(10, 18, 27, 0.24), rgba(10, 18, 27, 0.14)),
      linear-gradient(135deg, #243140, #162433 58%, #546e86);
  }

  .venue-preview__slide-overlay {
    position: absolute;
    inset: auto auto 1.6rem 1.6rem;
    width: min(360px, calc(100% - 3.2rem));
    padding: 1rem 1.05rem;
    border-radius: 18px;
    background: rgba(245, 245, 246, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    color: #f7f4ef;
  }

  .venue-preview__slide-label,
  .venue-preview__card-label {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .venue-preview__slide-overlay p {
    margin: 0.55rem 0 0;
  }

  .venue-preview__route-line {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
  }

  .venue-preview__route-line--a {
    right: -6%;
    top: -16%;
    width: 38%;
    height: 68%;
    border-top-color: rgba(255, 98, 40, 0.42);
    border-right-color: rgba(255, 98, 40, 0.42);
    transform: rotate(10deg);
    animation: mediaOrbit 30s linear infinite;
  }

  .venue-preview__route-line--b {
    left: -10%;
    bottom: -18%;
    width: 28%;
    height: 54%;
    border-bottom-color: rgba(141, 185, 216, 0.36);
    border-left-color: rgba(141, 185, 216, 0.36);
    transform: rotate(-18deg);
    animation: mediaOrbit 22s linear infinite reverse;
  }

  .venue-preview__card {
    position: absolute;
    z-index: 2;
    right: clamp(1rem, 4vw, 4rem);
    top: 50%;
    transform: translate3d(0, calc(-50% + var(--scroll-shift, 0px)), 0);
    width: min(420px, calc(100% - 2rem));
    padding: 1.3rem 1.25rem 1.1rem;
    border-radius: 24px;
    background: rgba(245, 245, 246, 0.95);
    box-shadow: 0 18px 48px rgba(6, 9, 12, 0.2);
  }

  .venue-preview__card-label {
    color: var(--accent);
  }

  .venue-preview__card h2 {
    margin: 0.25rem 0 0;
    color: #1e252b;
    font-size: clamp(2rem, 2.4vw, 2.8rem);
    line-height: 0.95;
  }

  .venue-preview__date,
  .venue-preview__copy {
    color: var(--ink-soft);
  }

  .venue-preview__date {
    margin: 0.55rem 0 0;
    font-weight: 700;
  }

  .venue-preview__copy {
    margin: 0.8rem 0 0;
  }

  .venue-preview__facts {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .venue-preview__fact {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    padding: 0.85rem 0.95rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(20, 32, 51, 0.08);
  }

  .venue-preview__fact span {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent);
  }

  .venue-preview__fact p {
    margin: 0;
  }

  .venue-preview__maps-link {
    margin-top: 1rem;
  }

  .venue-preview__dots {
    position: absolute;
    left: 50%;
    bottom: 1rem;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.42rem;
  }

  .venue-preview__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 0;
    background: rgba(255, 255, 255, 0.62);
    cursor: pointer;
  }

  .venue-preview__dot.is-active {
    background: #fff;
    transform: scale(1.2);
  }

  @media (max-width: 900px) {
    .venue-preview__carousel {
      min-height: clamp(640px, 92vh, 860px);
    }

    .venue-preview__card {
      position: relative;
      right: auto;
      top: auto;
      transform: translate3d(0, var(--scroll-shift, 0px), 0);
      margin: 10rem auto 2.5rem;
    }
  }
</style>
