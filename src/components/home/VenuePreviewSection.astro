---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent, getLabels, siteConfig } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { venue } = getHomepageContent(locale);
const venueVisualLabel = locale === 'it' ? 'Sant’Anna placeholder' : 'Sant’Anna placeholder';
const venueRouteEyebrow = locale === 'it' ? 'Apri la pagina sede' : 'Open venue page';
const travelTags =
  locale === 'it'
    ? ['Pisa Centrale', 'Galileo Galilei Airport', 'Centro storico']
    : ['Pisa Centrale', 'Galileo Galilei Airport', 'Historic centre'];
---

<section id="venue-preview" class="venue-preview" data-home-reveal>
  <div class="venue-preview__stage">
    <div class="container venue-preview__layout">
      <div class="venue-preview__copy" data-reveal-item>
        <p class="section-kicker">{venue.eyebrow}</p>
        <h2>{venue.title}</h2>
        <p>{venue.intro}</p>

        <div class="venue-preview__facts">
          {venue.facts.map((fact, index) => (
            <article class="venue-preview__fact" style={`--reveal-delay: ${index * 80 + 90}ms;`} data-reveal-item>
              <span>0{index + 1}</span>
              <p>{fact}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="media-shell media-shell--video venue-preview__visual" aria-hidden="true" data-reveal-item style="--reveal-delay: 120ms;">
        <span class="media-shell__label">{venueVisualLabel}</span>
        <span class="media-shell__badge">{labels.venue}</span>
        <span class="media-shell__grid"></span>
        <span class="media-shell__scan"></span>
        <span class="media-shell__orbit"></span>
        <span class="media-shell__beam"></span>
        <span class="media-shell__frame"></span>
        <span class="venue-preview__arch"></span>
        <span class="venue-preview__tile venue-preview__tile--a"></span>
        <span class="venue-preview__tile venue-preview__tile--b"></span>
        <div class="media-shell__caption">
          <span class="media-shell__eyebrow">{siteConfig.eventDate}</span>
          <strong>{siteConfig.venue}</strong>
          <p>{venue.travelBody}</p>
        </div>
      </div>

      <div class="venue-preview__side">
        <aside class="venue-preview__card" data-reveal-item style="--reveal-delay: 180ms;">
          <p class="venue-preview__card-label">{labels.venue}</p>
          <h3>{siteConfig.venue}</h3>
          <p class="venue-preview__date">{siteConfig.eventDate}</p>
          <p class="venue-preview__travel-title">{venue.travelTitle}</p>
          <p>{venue.travelBody}</p>

          <div class="venue-preview__tags">
            {travelTags.map((tag, index) => (
              <span style={`--reveal-delay: ${index * 60 + 200}ms;`} data-reveal-item>{tag}</span>
            ))}
          </div>
        </aside>

        <a class="route-card venue-preview__route" href={buildLocalizedPath(locale, 'venue')} data-reveal-item style="--reveal-delay: 230ms;">
          <span class="route-card__eyebrow">{venueRouteEyebrow}</span>
          <h2>{labels.venue}</h2>
          <p>{locale === 'it' ? 'Logistica, arrivi e dettagli della sede raccolti in un’unica pagina.' : 'Logistics, arrival notes, and venue details collected on one page.'}</p>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .venue-preview {
    padding: 1.2rem 0 2rem;
  }

  .venue-preview__stage {
    position: relative;
    width: min(1240px, 96%);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 2.8rem) 0;
    border-radius: 38px;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgba(55, 95, 138, 0.34), transparent 32%),
      linear-gradient(135deg, rgba(126, 36, 52, 0.88), rgba(20, 32, 51, 0.92));
    box-shadow: var(--shadow-strong);
  }

  .venue-preview__stage::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 42px 42px;
    opacity: 0.18;
    pointer-events: none;
  }

  .venue-preview__layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(300px, 0.95fr) minmax(280px, 0.78fr);
    gap: 1rem;
    align-items: stretch;
  }

  .venue-preview__copy,
  .venue-preview__card {
    color: #f8f4ef;
  }

  .venue-preview__copy h2 {
    margin: 0.3rem 0 0.8rem;
    font-size: clamp(2.5rem, 5vw, 4.3rem);
    line-height: 0.93;
    max-width: 11ch;
  }

  .venue-preview__copy p {
    max-width: 42rem;
    color: rgba(248, 244, 239, 0.84);
  }

  .venue-preview__facts {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .venue-preview__fact {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .venue-preview__fact span {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  .venue-preview__fact p {
    margin: 0;
  }

  .venue-preview__visual {
    min-height: 100%;
  }

  .venue-preview__arch,
  .venue-preview__tile {
    position: absolute;
    pointer-events: none;
  }

  .venue-preview__arch {
    left: 18%;
    right: 18%;
    bottom: 20%;
    height: 42%;
    border-radius: 999px 999px 0 0;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-bottom: 0;
  }

  .venue-preview__tile {
    width: 7rem;
    height: 7rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 16px 30px rgba(5, 10, 16, 0.16);
  }

  .venue-preview__tile--a {
    left: 14%;
    top: 16%;
  }

  .venue-preview__tile--b {
    right: 16%;
    top: 24%;
  }

  .venue-preview__side {
    display: grid;
    gap: 0.9rem;
  }

  .venue-preview__card {
    border-radius: 28px;
    padding: 1.4rem;
    background: rgba(255, 253, 249, 0.9);
    color: var(--ink);
    box-shadow: 0 22px 46px rgba(5, 10, 16, 0.22);
  }

  .venue-preview__card-label,
  .venue-preview__travel-title {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .venue-preview__card h3 {
    margin: 0.45rem 0 0;
    font-size: 2.1rem;
    line-height: 0.95;
  }

  .venue-preview__date {
    margin: 0.45rem 0 1rem;
    color: var(--ink-soft);
    font-weight: 700;
  }

  .venue-preview__travel-title {
    margin-top: 0.95rem;
  }

  .venue-preview__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .venue-preview__tags span {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(20, 32, 51, 0.08);
    color: var(--ink);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .venue-preview__route {
    background: rgba(255, 253, 249, 0.88);
  }

  @media (max-width: 1080px) {
    .venue-preview__layout {
      grid-template-columns: 1fr;
    }

    .venue-preview__visual {
      min-height: 14rem;
    }
  }
</style>
