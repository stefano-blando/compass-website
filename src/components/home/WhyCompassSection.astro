---
import type { Locale } from '../../data/types';
import { getHomepageContent } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { whyCompass } = getHomepageContent(locale);
const flowLabels =
  locale === 'it'
    ? ['Metodi AI', 'Networks & NLP', 'Diritto ed etica']
    : ['AI methods', 'Networks & NLP', 'Law and ethics'];
---

<section id="why-compass" class="why-compass" data-home-reveal>
  <div class="why-compass__glow why-compass__glow--warm" aria-hidden="true"></div>
  <div class="why-compass__glow why-compass__glow--cool" aria-hidden="true"></div>

  <div class="container why-compass__layout">
    <div class="why-compass__intro" data-reveal-item>
      <p class="section-kicker">{whyCompass.eyebrow}</p>
      <h2>{whyCompass.title}</h2>
      <p class="why-compass__lead">{whyCompass.intro}</p>

      <div class="why-compass__flow" aria-hidden="true">
        {flowLabels.map((label, index) => (
          <div class="why-compass__flow-item" style={`--reveal-delay: ${index * 80 + 120}ms;`} data-reveal-item>
            <span>0{index + 1}</span>
            <strong>{label}</strong>
          </div>
        ))}
      </div>
    </div>

    <aside class="why-compass__aside" data-reveal-item style="--reveal-delay: 120ms;">
      <p class="section-kicker">{whyCompass.asideTitle}</p>
      <p class="why-compass__aside-copy">{whyCompass.asideBody}</p>
      <ul class="why-compass__list">
        {whyCompass.asidePoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </aside>

    <div class="why-compass__pillars">
      {whyCompass.pillars.map((pillar, index) => (
        <article class="why-compass__card" style={`--reveal-delay: ${index * 95 + 100}ms;`} data-reveal-item>
          <p class="why-compass__card-index">0{index + 1}</p>
          <h3>{pillar.title}</h3>
          <p>{pillar.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-compass {
    position: relative;
    padding: 1rem 0 1.8rem;
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 540ms ease,
      transform 540ms ease;
  }

  .why-compass.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .why-compass__glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(54px);
    opacity: 0.22;
    pointer-events: none;
  }

  .why-compass__glow--warm {
    top: 6%;
    left: 4%;
    width: 16rem;
    height: 16rem;
    background: rgba(126, 36, 52, 0.28);
  }

  .why-compass__glow--cool {
    right: 8%;
    bottom: 2%;
    width: 18rem;
    height: 18rem;
    background: rgba(55, 95, 138, 0.24);
  }

  .why-compass__layout {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.9fr);
    gap: 1.2rem;
  }

  .why-compass__intro,
  .why-compass__card,
  .why-compass__aside {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.62);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .why-compass__intro,
  .why-compass__aside {
    padding: clamp(1.6rem, 3vw, 2rem);
  }

  .why-compass__intro {
    background:
      radial-gradient(circle at top right, rgba(55, 95, 138, 0.14), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(255, 253, 249, 0.72)),
      var(--surface);
  }

  .why-compass__intro h2 {
    margin: 0.3rem 0 0.8rem;
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    line-height: 0.93;
    max-width: 13ch;
  }

  .why-compass__lead,
  .why-compass__card p,
  .why-compass__aside-copy,
  .why-compass__list li {
    color: var(--ink-soft);
  }

  .why-compass__flow {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .why-compass__flow-item {
    position: relative;
    min-height: 7.4rem;
    padding: 1rem;
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.16)),
      rgba(20, 32, 51, 0.03);
    border: 1px solid rgba(20, 32, 51, 0.08);
    display: grid;
    align-content: end;
    gap: 0.35rem;
  }

  .why-compass__flow-item::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(20, 32, 51, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20, 32, 51, 0.05) 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.38;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent);
  }

  .why-compass__flow-item span,
  .why-compass__card-index {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent-cool);
  }

  .why-compass__flow-item strong {
    position: relative;
    z-index: 1;
    font-size: 1.12rem;
    line-height: 1.15;
  }

  .why-compass__pillars {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    grid-column: 1 / -1;
  }

  .why-compass__card {
    padding: 1.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 253, 249, 0.96)),
      var(--surface);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .why-compass__card::before {
    content: "";
    position: absolute;
    inset: -18% 42% 42% -10%;
    background: radial-gradient(circle, rgba(126, 36, 52, 0.14), transparent 70%);
    opacity: 0;
    transition: opacity 220ms ease;
  }

  .why-compass__card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-strong);
    border-color: rgba(55, 95, 138, 0.16);
  }

  .why-compass__card:hover::before {
    opacity: 1;
  }

  .why-compass__card h3 {
    position: relative;
    z-index: 1;
    margin: 0.45rem 0 0.55rem;
    font-size: 1.9rem;
    line-height: 0.98;
  }

  .why-compass__aside {
    background:
      radial-gradient(circle at top left, rgba(126, 36, 52, 0.12), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.76)),
      var(--surface-strong);
  }

  .why-compass__list {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  .why-compass__list li + li {
    margin-top: 0.55rem;
  }

  @media (max-width: 980px) {
    .why-compass__layout,
    .why-compass__pillars,
    .why-compass__flow {
      grid-template-columns: 1fr;
    }
  }
</style>
