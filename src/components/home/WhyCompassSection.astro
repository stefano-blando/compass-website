---
import type { Locale } from '../../data/types';
import { getHomepageContent } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { whyCompass } = getHomepageContent(locale);
---

<section id="why-compass" class="why-compass" data-home-reveal>
  <div class="container why-compass__layout">
    <div class="why-compass__intro">
      <p class="section-kicker">{whyCompass.eyebrow}</p>
      <h2>{whyCompass.title}</h2>
      <p class="why-compass__lead">{whyCompass.intro}</p>
    </div>

    <div class="why-compass__pillars">
      {whyCompass.pillars.map((pillar, index) => (
        <article class="why-compass__card" style={`--reveal-delay: ${index * 80}ms;`}>
          <p class="why-compass__card-index">0{index + 1}</p>
          <h3>{pillar.title}</h3>
          <p>{pillar.body}</p>
        </article>
      ))}
    </div>

    <aside class="why-compass__aside">
      <p class="section-kicker">{whyCompass.asideTitle}</p>
      <p class="why-compass__aside-copy">{whyCompass.asideBody}</p>
      <ul class="why-compass__list">
        {whyCompass.asidePoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </aside>
  </div>
</section>

<style>
  .why-compass {
    padding: 1rem 0 1.8rem;
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 540ms ease,
      transform 540ms ease;
  }

  .why-compass.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .why-compass__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1.3fr);
    gap: 1.2rem;
  }

  .why-compass__intro,
  .why-compass__card,
  .why-compass__aside {
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.62);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .why-compass__intro,
  .why-compass__aside {
    padding: clamp(1.6rem, 3vw, 2rem);
  }

  .why-compass__intro h2 {
    margin: 0.3rem 0 0.8rem;
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    line-height: 0.93;
    max-width: 12ch;
  }

  .why-compass__lead,
  .why-compass__card p,
  .why-compass__aside-copy,
  .why-compass__list li {
    color: var(--ink-soft);
  }

  .why-compass__pillars {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    grid-column: 1 / -1;
  }

  .why-compass__card {
    padding: 1.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.94)),
      var(--surface);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .why-compass__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-strong);
  }

  .why-compass__card-index {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent-cool);
  }

  .why-compass__card h3 {
    margin: 0.4rem 0 0.55rem;
    font-size: 1.85rem;
    line-height: 0.98;
  }

  .why-compass__aside {
    background:
      linear-gradient(180deg, rgba(126, 36, 52, 0.08), rgba(255, 255, 255, 0)),
      var(--surface-strong);
  }

  .why-compass__list {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  .why-compass__list li + li {
    margin-top: 0.55rem;
  }

  @media (max-width: 980px) {
    .why-compass__layout {
      grid-template-columns: 1fr;
    }

    .why-compass__pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
