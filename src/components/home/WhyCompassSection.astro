---
import type { Locale } from '../../data/types';
import { getHomepageContent } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { whyCompass } = getHomepageContent(locale);
---

<section id="why-compass" class="why-compass" data-home-reveal>
  <div class="why-compass__band">
    <div class="container why-compass__shell">
      <div class="why-compass__header">
        <div class="why-compass__copy" data-reveal-item>
          <p class="section-kicker">{whyCompass.eyebrow}</p>
          <h2>{whyCompass.title}</h2>
          <p class="why-compass__lead">{whyCompass.intro}</p>
        </div>
      </div>

      <div class="why-compass__pillars">
        {whyCompass.pillars.map((pillar, index) => (
          <article class="why-compass__pillar" data-reveal-item style={`--reveal-delay: ${100 + index * 80}ms`}>
            <div class="why-compass__pillar-number">0{index + 1}</div>
            <h3>{pillar.title}</h3>
            <p>{pillar.body}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .why-compass {
    position: relative;
    padding: 3rem 0 5rem;
    overflow: hidden;
  }

  .why-compass__band {
    background:
      radial-gradient(circle at 10% 20%, rgba(126, 36, 52, 0.05), transparent 30%),
      radial-gradient(circle at 90% 80%, rgba(55, 95, 138, 0.05), transparent 30%);
  }

  .why-compass__shell {
    display: grid;
    gap: 3.5rem;
  }

  .why-compass__header {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .why-compass__copy h2 {
    margin: 0.5rem 0 1.2rem;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 0.95;
    color: var(--ink);
  }

  .why-compass__lead {
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .why-compass__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .why-compass__pillar {
    position: relative;
    padding: 2.2rem;
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 40px rgba(20, 32, 51, 0.04);
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .why-compass__pillar:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(20, 32, 51, 0.08);
    background: rgba(255, 255, 255, 0.85);
  }

  .why-compass__pillar-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--accent), var(--ink-soft));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0.35;
  }

  .why-compass__pillar h3 {
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
    line-height: 1.1;
    color: var(--ink);
  }

  .why-compass__pillar p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  @media (max-width: 980px) {
    .why-compass__pillars {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }
    
    .why-compass {
      padding: 3rem 0;
    }
  }
</style>
