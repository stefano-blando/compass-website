---
import type { Locale } from '../../data/types';
import {
  buildLocalizedPath,
  getHomepageContent,
  getHomepageFeaturedSpeakers,
  getLabels,
  getSpeakerBySlug,
  resolvePublicPath,
} from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { speakers } = getHomepageContent(locale);
const featuredSpeakers = getHomepageFeaturedSpeakers(locale);
const portraitLabel = locale === 'it' ? 'Ritratto placeholder' : 'Portrait placeholder';
const carouselLabel = locale === 'it' ? 'Scorri i relatori' : 'Browse speakers';
---

<section id="featured-speakers" class="featured-speakers" data-home-reveal>
  <div class="container featured-speakers__shell">
    <div class="featured-speakers__head">
      <div data-reveal-item>
        <p class="section-kicker">{speakers.eyebrow}</p>
        <h2>{speakers.title}</h2>
      </div>

      <div class="featured-speakers__head-copy" data-reveal-item style="--reveal-delay: 90ms;">
        <p>{speakers.intro}</p>
        <p>{speakers.note}</p>
      </div>
    </div>

    <div class="featured-speakers__carousel" data-speaker-carousel>
      <button type="button" class="featured-speakers__nav" data-dir="prev" aria-label={locale === 'it' ? 'Relatori precedenti' : 'Previous speakers'}>
        ←
      </button>

      <div class="featured-speakers__viewport" data-speaker-viewport aria-label={carouselLabel} data-scroll-shift data-scroll-speed="16">
        <div class="featured-speakers__track">
          {featuredSpeakers.map((speaker, index) => (
            <article
              class="featured-speakers__card"
              style={`--reveal-delay: ${index * 70}ms;`}
              data-reveal-item
              data-scroll-shift
              data-scroll-speed={String(14 + (index % 3) * 5)}
              data-scroll-direction={index % 2 === 0 ? '-1' : '1'}
            >
              <div class="media-shell media-shell--light media-shell--portrait featured-speakers__media featured-speakers__media-shell" aria-hidden="true" data-scroll-shift data-scroll-speed={String(10 + (index % 3) * 4)} data-scroll-direction={index % 2 === 0 ? '1' : '-1'}>
                <span class="media-shell__label">{portraitLabel}</span>
                <span class="media-shell__badge">{speaker.role}</span>
                <span class="media-shell__grid"></span>
                <span class="media-shell__scan"></span>
                <span class="media-shell__beam"></span>
                <span class="media-shell__frame"></span>
                <span class="featured-speakers__card-media-orbit featured-speakers__card-media-orbit--outer"></span>
                <span class="featured-speakers__card-media-orbit featured-speakers__card-media-orbit--inner"></span>
                <span class="featured-speakers__card-media-route"></span>
                
                {speaker.slug === 'guido-germano' || speaker.slug === 'prabhani-don' ? (
                   <>
                    <span class="media-shell__person media-shell__person--soft featured-speakers__figure featured-speakers__figure--left"></span>
                    <span class="media-shell__person featured-speakers__figure featured-speakers__figure--right"></span>
                   </>
                ) : null}

                {getSpeakerBySlug(speaker.slug)?.image ? (
                  <div class="featured-speakers__photo">
                    <img src={resolvePublicPath(getSpeakerBySlug(speaker.slug)!.image!)} alt={speaker.name} />
                  </div>
                ) : (
                  <div class="featured-speakers__monogram">
                    {speaker.name
                      .split(' ')
                      .map((part) => part[0])
                      .slice(0, 2)
                      .join('')}
                  </div>
                )}

                <div class="media-shell__caption">
                  <span class="media-shell__eyebrow">{portraitLabel}</span>
                  <strong>{speaker.name}</strong>
                  <p>{speaker.affiliation}</p>
                </div>
              </div>

              <p class="featured-speakers__role">{speaker.role}</p>
              <h3>{speaker.name}</h3>
              <p class="featured-speakers__affiliation">{speaker.affiliation}</p>
              <p class="featured-speakers__bio">{speaker.bio}</p>

              <div class="featured-speakers__talk">
                <span>{locale === 'it' ? 'Contributo' : 'Contribution'}</span>
                <strong>{speaker.talkTitle ?? speakers.emptyTalkLabel}</strong>
              </div>
            </article>
          ))}
        </div>
      </div>

      <button type="button" class="featured-speakers__nav" data-dir="next" aria-label={locale === 'it' ? 'Relatori successivi' : 'Next speakers'}>
        →
      </button>
    </div>

    <a class="btn-secondary" href={buildLocalizedPath(locale, 'speakers')} data-reveal-item style="--reveal-delay: 140ms;">
      {labels.speakers}
    </a>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-speaker-carousel]');
    if (!root) {
      return;
    }

    const viewport = root.querySelector('[data-speaker-viewport]');
    const prev = root.querySelector('[data-dir="prev"]');
    const next = root.querySelector('[data-dir="next"]');
    if (!viewport || !prev || !next) {
      return;
    }

    const step = () => Math.max(viewport.clientWidth * 0.82, 280);

    prev.addEventListener('click', () => {
      viewport.scrollBy({ left: -step(), behavior: 'smooth' });
    });

    next.addEventListener('click', () => {
      viewport.scrollBy({ left: step(), behavior: 'smooth' });
    });
  })();
</script>

<style>
  .featured-speakers {
    padding: 1.2rem 0 2rem;
  }

  .featured-speakers__shell {
    position: relative;
    display: grid;
    gap: 1.3rem;
  }

  .featured-speakers__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.82fr);
    gap: 1rem;
    align-items: end;
  }

  .featured-speakers__head h2 {
    margin: 0.3rem 0 0;
    font-size: clamp(2.4rem, 5vw, 4.3rem);
    line-height: 0.93;
    max-width: 12ch;
  }

  .featured-speakers__head-copy p {
    color: var(--ink-soft);
  }

  .featured-speakers__carousel {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: center;
  }

  .featured-speakers__viewport {
    overflow-x: auto;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
    transform: translate3d(0, calc(var(--scroll-shift, 0px) * 0.55), 0);
  }

  .featured-speakers__viewport::-webkit-scrollbar {
    display: none;
  }

  .featured-speakers__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(320px, 1fr);
    gap: 0.9rem;
  }

  .featured-speakers__card {
    position: relative;
    overflow: hidden;
    scroll-snap-align: start;
    min-height: 100%;
    border-radius: 26px;
    padding: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.62);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 253, 249, 0.98)),
      var(--surface);
    box-shadow: var(--shadow);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
    transform: translate3d(0, var(--scroll-shift, 0px), 0);
  }

  .featured-speakers__card:hover {
    transform: translate3d(0, calc(var(--scroll-shift, 0px) - 5px), 0);
    box-shadow: var(--shadow-strong);
    border-color: rgba(55, 95, 138, 0.18);
  }

  .featured-speakers__media {
    margin-bottom: 1.05rem;
    box-shadow: none;
  }

  .featured-speakers__media-shell {
    transform: translate3d(0, calc(var(--scroll-shift, 0px) * 0.75), 0);
  }

  .featured-speakers__card-media-orbit,
  .featured-speakers__card-media-route {
    position: absolute;
    pointer-events: none;
  }

  .featured-speakers__card-media-orbit {
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    animation: mediaOrbit 22s linear infinite;
  }

  .featured-speakers__card-media-orbit--outer {
    inset: 8% 10% auto auto;
    width: 58%;
    height: 58%;
    border-left-color: rgba(255, 98, 40, 0.42);
    border-top-color: rgba(255, 98, 40, 0.42);
  }

  .featured-speakers__card-media-orbit--inner {
    inset: auto auto 12% 12%;
    width: 34%;
    height: 34%;
    border-right-color: rgba(55, 95, 138, 0.42);
    border-bottom-color: rgba(55, 95, 138, 0.42);
    animation-direction: reverse;
    animation-duration: 18s;
  }

  .featured-speakers__card-media-route {
    inset: 18% 14% 26% 14%;
    background:
      radial-gradient(circle at 18% 32%, rgba(255, 255, 255, 0.2) 0 3px, transparent 4px),
      radial-gradient(circle at 82% 64%, rgba(255, 98, 40, 0.24) 0 3px, transparent 4px),
      linear-gradient(128deg, transparent 16%, rgba(255, 255, 255, 0.18) 17%, rgba(255, 255, 255, 0.18) 18%, transparent 19%),
      linear-gradient(24deg, transparent 58%, rgba(141, 185, 216, 0.18) 59%, rgba(141, 185, 216, 0.18) 60%, transparent 61%);
    opacity: calc(0.45 + var(--section-progress, 0) * 0.2);
  }

  .featured-speakers__figure--left {
    left: 18%;
    --person-width: 4.2rem;
    --person-height: 7.1rem;
  }

  .featured-speakers__figure--right {
    right: 18%;
    --person-width: 4.6rem;
    --person-height: 8rem;
  }

  .featured-speakers__photo {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .featured-speakers__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    mix-blend-mode: luminosity;
    opacity: 0.88;
    transition: opacity 220ms ease, mix-blend-mode 220ms ease;
  }

  .featured-speakers__card:hover .featured-speakers__photo img {
    mix-blend-mode: normal;
    opacity: 1;
  }

  .featured-speakers__monogram {
    position: absolute;
    left: 1rem;
    bottom: 5.7rem;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--ink);
    font-weight: 800;
    letter-spacing: 0.08em;
    box-shadow: 0 14px 28px rgba(20, 32, 51, 0.18);
  }

  .featured-speakers__role,
  .featured-speakers__affiliation,
  .featured-speakers__bio,
  .featured-speakers__talk span {
    color: var(--ink-soft);
  }

  .featured-speakers__role {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .featured-speakers__card h3 {
    margin: 0.4rem 0 0;
    font-size: 2rem;
    line-height: 0.95;
  }

  .featured-speakers__affiliation {
    margin: 0.3rem 0 0;
    font-weight: 700;
  }

  .featured-speakers__bio {
    margin: 0.85rem 0 0;
  }

  .featured-speakers__talk {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 0.15rem;
  }

  .featured-speakers__talk span {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .featured-speakers__nav {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 999px;
    border: 1px solid rgba(20, 32, 51, 0.12);
    background: rgba(255, 255, 255, 0.72);
    color: var(--ink);
    box-shadow: var(--shadow);
    cursor: pointer;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .featured-speakers__nav:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-strong);
  }

  @media (max-width: 980px) {
    .featured-speakers__head {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .featured-speakers__carousel {
      grid-template-columns: 1fr;
    }

    .featured-speakers__nav {
      display: none;
    }
  }
</style>
