---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent, getLabels, siteConfig } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { registration } = getHomepageContent(locale);
const tags =
  locale === 'it'
    ? ['In presenza', 'Partecipazione gratuita', 'Pisa']
    : ['In person', 'Free attendance', 'Pisa'];
---

<section id="registration-cta" class="registration-cta" data-home-reveal>
  <div class="container registration-cta__shell">
    <div class="registration-cta__copy" data-reveal-item>
      <p class="section-kicker">{registration.eyebrow}</p>
      <h2>{registration.title}</h2>
      <p>{registration.intro}</p>

      <div class="registration-cta__tags" aria-hidden="true">
        {tags.map((tag, index) => (
          <span style={`--reveal-delay: ${index * 70 + 100}ms;`} data-reveal-item>{tag}</span>
        ))}
      </div>

      <div class="registration-cta__actions">
        <a class="btn-primary" href={buildLocalizedPath(locale, 'registration')}>{labels.registration}</a>
        <a class="btn-secondary" href={siteConfig.registrationUrl} target="_blank" rel="noreferrer">
          {registration.secondaryCta}
        </a>
      </div>
    </div>

    <aside class="registration-cta__panel" data-reveal-item style="--reveal-delay: 120ms;">
      <div class="registration-cta__panel-art" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <p class="registration-cta__deadline-label">{registration.deadlineLabel}</p>
      <p class="registration-cta__deadline-value">{registration.deadlineValue}</p>

      <ul class="registration-cta__list">
        {registration.checklist.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </aside>
  </div>
</section>

<style>
  .registration-cta {
    padding: 1.2rem 0 0;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 520ms ease,
      transform 520ms ease;
  }

  .registration-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .registration-cta__shell {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.72fr);
    gap: 1rem;
    padding: clamp(1.7rem, 4vw, 2.3rem);
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.62);
    background:
      radial-gradient(circle at top right, rgba(55, 95, 138, 0.12), transparent 30%),
      linear-gradient(180deg, rgba(126, 36, 52, 0.08), rgba(255, 255, 255, 0.82)),
      var(--surface-strong);
    box-shadow: var(--shadow);
  }

  .registration-cta__copy h2 {
    margin: 0.3rem 0 0.8rem;
    font-size: clamp(2.4rem, 5vw, 4.3rem);
    line-height: 0.93;
    max-width: 12ch;
  }

  .registration-cta__copy p,
  .registration-cta__list li {
    color: var(--ink-soft);
  }

  .registration-cta__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.2rem;
  }

  .registration-cta__tags span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.2rem;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(20, 32, 51, 0.08);
    background: rgba(255, 255, 255, 0.78);
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .registration-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .registration-cta__panel {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    padding: 1.4rem;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(20, 32, 51, 0.08);
  }

  .registration-cta__panel-art {
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 4.2rem;
    pointer-events: none;
  }

  .registration-cta__panel-art span {
    position: absolute;
    border-radius: 999px;
  }

  .registration-cta__panel-art span:nth-child(1) {
    left: 1rem;
    top: 1rem;
    width: 5rem;
    height: 5rem;
    background: radial-gradient(circle, rgba(126, 36, 52, 0.16), transparent 70%);
  }

  .registration-cta__panel-art span:nth-child(2) {
    right: 1rem;
    top: 0.7rem;
    width: 6.4rem;
    height: 6.4rem;
    border: 1px solid rgba(55, 95, 138, 0.12);
    animation: registrationOrbit 11s linear infinite;
  }

  .registration-cta__panel-art span:nth-child(3) {
    left: 1.1rem;
    right: 1.1rem;
    top: 2.4rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(20, 32, 51, 0.08), rgba(55, 95, 138, 0.35), rgba(20, 32, 51, 0.08));
  }

  .registration-cta__deadline-label {
    position: relative;
    margin: 0;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
    z-index: 1;
  }

  .registration-cta__deadline-value {
    position: relative;
    z-index: 1;
    margin: 0.35rem 0 0;
    color: var(--ink);
    font-size: 2rem;
    line-height: 0.95;
    font-weight: 700;
    font-family: 'Cormorant Garamond', serif;
  }

  .registration-cta__list {
    position: relative;
    z-index: 1;
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  .registration-cta__list li + li {
    margin-top: 0.55rem;
  }

  @keyframes registrationOrbit {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 980px) {
    .registration-cta__shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .registration-cta__actions {
      flex-direction: column;
    }
  }
</style>
