---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent, getLabels, siteConfig } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { registration } = getHomepageContent(locale);
const tags =
  locale === 'it'
    ? ['In presenza', 'Partecipazione gratuita', 'Pisa']
    : ['In person', 'Free attendance', 'Pisa'];
const registrationMediaLabel = locale === 'it' ? 'Poster registrazione placeholder' : 'Registration poster placeholder';
const registrationRouteLabel = locale === 'it' ? 'Passaggio rapido' : 'Quick handoff';
---

<section id="registration-cta" class="registration-cta" data-home-reveal>
  <div class="container registration-cta__shell">
    <div class="registration-cta__copy" data-reveal-item>
      <p class="section-kicker">{registration.eyebrow}</p>
      <h2>{registration.title}</h2>
      <p>{registration.intro}</p>

      <div class="registration-cta__tags" aria-hidden="true">
        {tags.map((tag, index) => (
          <span style={`--reveal-delay: ${index * 70 + 100}ms;`} data-reveal-item>{tag}</span>
        ))}
      </div>

      <div class="registration-cta__actions">
        <a class="btn-primary" href={buildLocalizedPath(locale, 'registration')}>{labels.registration}</a>
        <a class="btn-secondary" href={siteConfig.registrationUrl} target="_blank" rel="noreferrer">
          {registration.secondaryCta}
        </a>
      </div>
    </div>

    <div class="registration-cta__stage">
      <div class="media-shell media-shell--video registration-cta__media" aria-hidden="true" data-reveal-item style="--reveal-delay: 120ms;">
        <span class="media-shell__label">{registrationMediaLabel}</span>
        <span class="media-shell__badge">{registrationRouteLabel}</span>
        <span class="media-shell__grid"></span>
        <span class="media-shell__scan"></span>
        <span class="media-shell__orbit"></span>
        <span class="media-shell__beam"></span>
        <span class="media-shell__frame"></span>
        <span class="registration-cta__ticket registration-cta__ticket--a"></span>
        <span class="registration-cta__ticket registration-cta__ticket--b"></span>
        <div class="media-shell__caption">
          <span class="media-shell__eyebrow">{registration.deadlineLabel}</span>
          <strong>{registration.deadlineValue}</strong>
          <p>{siteConfig.eventDate}</p>
        </div>
      </div>

      <aside class="registration-cta__panel" data-reveal-item style="--reveal-delay: 170ms;">
        <p class="registration-cta__deadline-label">{registration.deadlineLabel}</p>
        <p class="registration-cta__deadline-value">{registration.deadlineValue}</p>

        <ul class="registration-cta__list">
          {registration.checklist.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  .registration-cta {
    padding: 1.2rem 0 0;
  }

  .registration-cta__shell {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: 1rem;
    padding: clamp(1.7rem, 4vw, 2.3rem);
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.62);
    background:
      radial-gradient(circle at top right, rgba(55, 95, 138, 0.12), transparent 30%),
      linear-gradient(180deg, rgba(126, 36, 52, 0.08), rgba(255, 255, 255, 0.82)),
      var(--surface-strong);
    box-shadow: var(--shadow);
  }

  .registration-cta__copy h2 {
    margin: 0.3rem 0 0.8rem;
    font-size: clamp(2.4rem, 5vw, 4.3rem);
    line-height: 0.93;
    max-width: 12ch;
  }

  .registration-cta__copy p,
  .registration-cta__list li {
    color: var(--ink-soft);
  }

  .registration-cta__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.2rem;
  }

  .registration-cta__tags span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.2rem;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(20, 32, 51, 0.08);
    background: rgba(255, 255, 255, 0.78);
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .registration-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .registration-cta__stage {
    display: grid;
    gap: 0.9rem;
  }

  .registration-cta__media {
    min-height: clamp(15rem, 30vw, 20rem);
  }

  .registration-cta__ticket {
    position: absolute;
    width: 7.4rem;
    height: 5.2rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 16px 30px rgba(5, 10, 16, 0.16);
    pointer-events: none;
  }

  .registration-cta__ticket--a {
    left: 16%;
    top: 18%;
    transform: rotate(-8deg);
  }

  .registration-cta__ticket--b {
    right: 16%;
    top: 26%;
    transform: rotate(8deg);
  }

  .registration-cta__panel {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    padding: 1.4rem;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(20, 32, 51, 0.08);
  }

  .registration-cta__deadline-label {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .registration-cta__deadline-value {
    margin: 0.35rem 0 0;
    color: var(--ink);
    font-size: 2rem;
    line-height: 0.95;
    font-weight: 700;
    font-family: 'Cormorant Garamond', serif;
  }

  .registration-cta__list {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  .registration-cta__list li + li {
    margin-top: 0.55rem;
  }

  @media (max-width: 980px) {
    .registration-cta__shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .registration-cta__actions {
      flex-direction: column;
    }
  }
</style>
