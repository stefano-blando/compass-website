---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { programme } = getHomepageContent(locale);
---

<section id="programme-preview" class="programme-preview" data-home-reveal>
  <div class="container programme-preview__shell">
    <div class="programme-preview__intro" data-reveal-item>
      <p class="section-kicker">{programme.eyebrow}</p>
      <h2>{programme.title}</h2>
      <p>{programme.intro}</p>
    </div>

    <div class="programme-preview__grid">
      {programme.navCards.map((card, index) => (
        <a
          class="programme-preview__nav-card"
          href={buildLocalizedPath(locale, card.route)}
          data-reveal-item
          style={`--reveal-delay: ${index * 0.1 + 0.1}s;`}
        >
          <div class={`programme-preview__media programme-preview__media--${(index % 3) + 1}`} aria-hidden="true">
            <span class="programme-preview__media-label">{card.mediaLabel}</span>
            <span class="programme-preview__media-glow"></span>
            <span class="programme-preview__media-figure programme-preview__media-figure--left"></span>
            <span class="programme-preview__media-figure programme-preview__media-figure--right"></span>
          </div>
          <p class="programme-preview__card-eyebrow">{card.eyebrow}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
          <span class="programme-preview__meta">{card.meta}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .programme-preview {
    position: relative;
    background-color: #14232f;
    background-image: linear-gradient(180deg, #14232f 0%, #182833 44%, #1f3444 100%);
    padding: 4.6rem 0 3.8rem;
    color: #f2f4f7;
  }

  .programme-preview::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -140px;
    transform: translateX(-50%);
    width: min(980px, 94vw);
    height: 520px;
    background: repeating-radial-gradient(ellipse at 50% 0%, rgba(218, 227, 234, 0.1) 0 1px, transparent 1px 23px);
    opacity: 0.18;
    pointer-events: none;
  }

  .programme-preview__shell {
    position: relative;
    z-index: 1;
  }

  .programme-preview__intro {
    text-align: center;
    max-width: 50rem;
    margin: 0 auto 1.8rem;
  }

  .programme-preview__intro h2 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(2.2rem, 4.8vw, 4rem);
    line-height: 0.95;
    color: #f3f6f8;
  }

  .programme-preview__intro p {
    margin: 0;
    color: rgba(242, 244, 247, 0.76);
  }

  .programme-preview__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .programme-preview__nav-card {
    position: relative;
    display: grid;
    align-content: start;
    gap: 0.6rem;
    padding: 1rem;
    border-radius: 14px;
    text-decoration: none;
    background: #e7e7e7;
    color: #212528;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: 0 14px 32px rgba(2, 8, 14, 0.18);
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }

  .programme-preview__nav-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 26px 44px rgba(1, 10, 18, 0.24);
  }

  .programme-preview__media {
    position: relative;
    min-height: 13rem;
    overflow: hidden;
    border-radius: 10px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0)),
      linear-gradient(135deg, #3c5168, #223445 58%, #172636);
  }

  .programme-preview__media--2 {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0)),
      linear-gradient(135deg, #7b5a58, #aa8165 58%, #6b4a47);
  }

  .programme-preview__media--3 {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0)),
      linear-gradient(135deg, #233142, #14232f 58%, #35546d);
  }

  .programme-preview__media-label {
    position: absolute;
    left: 0.85rem;
    top: 0.85rem;
    z-index: 2;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
  }

  .programme-preview__media-glow {
    position: absolute;
    right: -12%;
    bottom: -20%;
    width: 68%;
    height: 68%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 98, 40, 0.3), rgba(255, 98, 40, 0) 72%);
    filter: blur(16px);
  }

  .programme-preview__media-figure {
    position: absolute;
    bottom: 1rem;
    width: 3.7rem;
    height: 6.7rem;
    border-radius: 999px 999px 20px 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0)),
      linear-gradient(180deg, rgba(251, 232, 224, 0.88), rgba(86, 37, 39, 0.95));
    box-shadow: 0 18px 32px rgba(5, 10, 16, 0.22);
  }

  .programme-preview__media-figure::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -1.5rem;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    transform: translateX(-50%);
    background:
      radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.75), rgba(255, 255, 255, 0.08)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.02));
  }

  .programme-preview__media-figure--left {
    left: 18%;
  }

  .programme-preview__media-figure--right {
    right: 16%;
    width: 3.2rem;
    height: 5.8rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0)),
      linear-gradient(180deg, rgba(211, 225, 240, 0.88), rgba(55, 95, 138, 0.94));
  }

  .programme-preview__card-eyebrow {
    margin: 0;
    color: #7c8489;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .programme-preview__nav-card h3 {
    margin: 0;
    font-size: clamp(1.28rem, 1.8vw, 1.84rem);
    line-height: 1.05;
  }

  .programme-preview__nav-card p {
    margin: 0;
    color: #31363d;
  }

  .programme-preview__meta {
    margin-top: auto;
    color: #61686d;
    font-size: 0.92rem;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .programme-preview__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
