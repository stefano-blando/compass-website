---
import type { Locale } from '../../data/types';
import { buildLocalizedPath, getHomepageContent, getHomepageProgrammePreview, getLabels } from '../../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getLabels(locale);
const { programme } = getHomepageContent(locale);
const sessions = getHomepageProgrammePreview(locale);
const timeFormatter = new Intl.DateTimeFormat(locale === 'it' ? 'it-IT' : 'en-GB', {
  hour: '2-digit',
  minute: '2-digit',
});
const sessionTypeLabels = {
  en: {
    opening: 'Opening',
    keynote: 'Keynote',
    panel: 'Panel',
    social: 'Social',
  },
  it: {
    opening: 'Apertura',
    keynote: 'Keynote',
    panel: 'Panel',
    social: 'Sociale',
  },
} as const;
const routeEyebrow = locale === 'it' ? 'Timeline completa' : 'Full timeline';
const routeCopy = locale === 'it' ? 'Apri il programma per vedere tutti i dodici blocchi della giornata.' : 'Open the programme page to see all twelve workshop blocks in sequence.';
const previewLabel = locale === 'it' ? 'Preview visivo' : 'Visual preview';
---

<section id="programme-preview" class="programme-preview" data-home-reveal>
  <div class="container programme-preview__shell">
    <div class="programme-preview__top">
      <div class="programme-preview__intro" data-reveal-item>
        <p class="section-kicker">{programme.eyebrow}</p>
        <h2>{programme.title}</h2>
        <p>{programme.intro}</p>
      </div>

      <a class="route-card programme-preview__route" href={buildLocalizedPath(locale, 'programme')} data-reveal-item style="--reveal-delay: 80ms;">
        <span class="route-card__eyebrow">{routeEyebrow}</span>
        <h2>{labels.viewProgramme}</h2>
        <p>{routeCopy}</p>
      </a>
    </div>

    <div class="programme-preview__lead" data-reveal-item style="--reveal-delay: 110ms;">
      <div class="media-shell media-shell--video programme-preview__lead-media" aria-hidden="true">
        <span class="media-shell__label">{previewLabel}</span>
        <span class="media-shell__badge">{programme.sessionLabel}</span>
        <span class="media-shell__grid"></span>
        <span class="media-shell__scan"></span>
        <span class="media-shell__orbit"></span>
        <span class="media-shell__beam"></span>
        <span class="media-shell__frame"></span>
        <span class="media-shell__person programme-preview__lead-figure programme-preview__lead-figure--left"></span>
        <span class="media-shell__person media-shell__person--soft programme-preview__lead-figure programme-preview__lead-figure--right"></span>
        <div class="media-shell__caption">
          <span class="media-shell__eyebrow">{programme.note}</span>
          <strong>{sessions[0]?.title}</strong>
          <p>{sessions[0]?.description}</p>
        </div>
      </div>
    </div>

    <div class="programme-preview__grid">
      {sessions.map((session, index) => (
        <article class="programme-preview__card" style={`--reveal-delay: ${index * 85 + 140}ms;`} data-reveal-item>
          <div class="media-shell programme-preview__card-media" aria-hidden="true">
            <span class="media-shell__label">{programme.sessionLabel}</span>
            <span class="media-shell__badge">{sessionTypeLabels[locale][session.type as keyof typeof sessionTypeLabels.en]}</span>
            <span class="media-shell__grid"></span>
            <span class="media-shell__scan"></span>
            <span class="media-shell__beam"></span>
            <span class="media-shell__frame"></span>
            <span class={`programme-preview__marker programme-preview__marker--${(index % 3) + 1}`}></span>
          </div>

          <p class="programme-preview__time">
            {timeFormatter.format(new Date(session.startsAt))} - {timeFormatter.format(new Date(session.endsAt))}
          </p>
          <h3>{session.title}</h3>
          <p>{session.description}</p>

          {session.chairNames.length > 0 && (
            <p class="programme-preview__meta">
              {session.chairLabel}: {session.chairNames.join(', ')}
            </p>
          )}

          {session.featuredTalkTitle && (
            <div class="programme-preview__talk">
              <span>{programme.talkLabel}</span>
              <strong>{session.featuredTalkTitle}</strong>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .programme-preview {
    padding: 1.2rem 0 2rem;
  }

  .programme-preview__shell {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 34px;
    padding: clamp(1.6rem, 4vw, 2.2rem);
    background:
      radial-gradient(circle at top right, rgba(55, 95, 138, 0.24), transparent 32%),
      radial-gradient(circle at bottom left, rgba(126, 36, 52, 0.22), transparent 28%),
      linear-gradient(180deg, #142033, #1d2d45);
    color: #f7f3ee;
    box-shadow: var(--shadow-strong);
  }

  .programme-preview__shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: 0.16;
    pointer-events: none;
  }

  .programme-preview__top,
  .programme-preview__lead,
  .programme-preview__grid {
    position: relative;
    z-index: 1;
  }

  .programme-preview__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.64fr);
    gap: 1rem;
    align-items: end;
  }

  .programme-preview__intro h2 {
    margin: 0.3rem 0 0.75rem;
    font-size: clamp(2.3rem, 5vw, 4rem);
    line-height: 0.93;
    max-width: 13ch;
  }

  .programme-preview__intro p {
    margin: 0;
    max-width: 54rem;
    color: rgba(247, 243, 238, 0.82);
  }

  .programme-preview__route {
    min-height: 100%;
    background:
      linear-gradient(180deg, rgba(255, 253, 249, 0.18), rgba(255, 253, 249, 0.08)),
      rgba(255, 253, 249, 0.08);
    border-color: rgba(255, 255, 255, 0.14);
    color: #f7f3ee;
  }

  .programme-preview__route .route-card__eyebrow,
  .programme-preview__route p {
    color: rgba(247, 243, 238, 0.72);
  }

  .programme-preview__lead-media {
    min-height: clamp(16rem, 32vw, 22rem);
  }

  .programme-preview__lead-figure--left {
    left: 22%;
    --person-width: 5rem;
    --person-height: 8.5rem;
  }

  .programme-preview__lead-figure--right {
    right: 20%;
    --person-width: 4.2rem;
    --person-height: 7.4rem;
  }

  .programme-preview__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.9rem;
  }

  .programme-preview__card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    padding: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 253, 249, 0.16), rgba(255, 253, 249, 0.08)),
      rgba(255, 253, 249, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 18px 36px rgba(5, 10, 16, 0.18);
    backdrop-filter: blur(12px);
  }

  .programme-preview__card-media {
    min-height: 8.4rem;
    margin-bottom: 0.9rem;
    box-shadow: none;
  }

  .programme-preview__marker {
    position: absolute;
    inset: auto;
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 999px;
    filter: blur(3px);
  }

  .programme-preview__marker--1 {
    left: 16%;
    bottom: 20%;
    background: radial-gradient(circle, rgba(236, 193, 201, 0.44), rgba(236, 193, 201, 0) 72%);
  }

  .programme-preview__marker--2 {
    right: 16%;
    top: 18%;
    background: radial-gradient(circle, rgba(55, 95, 138, 0.34), rgba(55, 95, 138, 0) 72%);
  }

  .programme-preview__marker--3 {
    left: calc(50% - 2.2rem);
    top: calc(50% - 2.2rem);
    background: radial-gradient(circle, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 72%);
  }

  .programme-preview__time,
  .programme-preview__meta,
  .programme-preview__card p,
  .programme-preview__talk span {
    color: rgba(247, 243, 238, 0.8);
  }

  .programme-preview__time {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .programme-preview__card h3 {
    margin: 0.55rem 0 0.45rem;
    font-size: 2rem;
    line-height: 0.96;
  }

  .programme-preview__meta {
    margin: 0.9rem 0 0;
    font-size: 0.95rem;
  }

  .programme-preview__talk {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    display: grid;
    gap: 0.15rem;
  }

  .programme-preview__talk span {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .programme-preview__top {
      grid-template-columns: 1fr;
    }
  }
</style>
