---
import { speakers } from '../../data/speakers';
import { resolvePublicPath } from '../../lib/site';

const featuredSpeakers = speakers.filter(s => 
  ['guido-germano', 'prabhani-don', 'federica-casarosa', 'stefano-blando', 'biancamaria-bombino', 'lorenzo-emer', 'alice-musso', 'roberta-romano', 'roberta-savella'].includes(s.slug)
);

// Map slugs to positions for a nice constellation
const positions: Record<string, { top: string, left: string, size: string }> = {
  'guido-germano': { top: '22%', left: '18%', size: '100px' },
  'prabhani-don': { top: '78%', left: '18%', size: '100px' },
  'federica-casarosa': { top: '50%', left: '82%', size: '100px' },
  'stefano-blando': { top: '40%', left: '45%', size: '90px' },
  'lorenzo-emer': { top: '15%', left: '42%', size: '80px' },
  'biancamaria-bombino': { top: '65%', left: '35%', size: '80px' },
  'alice-musso': { top: '85%', left: '55%', size: '80px' },
  'roberta-romano': { top: '25%', left: '70%', size: '85px' },
  'roberta-savella': { top: '75%', left: '70%', size: '80px' },
};
---

<div class="speaker-network">
  <svg class="network-lines" viewBox="0 0 100 100" preserveAspectRatio="none">
    <!-- Hub Blando connections -->
    <line x1="45" y1="40" x2="18" y2="22" class="line-a" />
    <line x1="45" y1="40" x2="18" y2="78" class="line-b" />
    <line x1="45" y1="40" x2="70" y2="25" class="line-c" />
    <line x1="45" y1="40" x2="70" y2="75" class="line-d" />
    <line x1="45" y1="40" x2="42" y2="15" class="line-e" />
    <line x1="45" y1="40" x2="35" y2="65" class="line-f" />
    
    <!-- Periphery connections -->
    <line x1="42" y1="15" x2="18" y2="22" class="line-g" />
    <line x1="35" y1="65" x2="18" y2="78" class="line-h" />
    <line x1="55" y1="85" x2="18" y2="78" class="line-i" />
    <line x1="70" y1="25" x2="82" y2="50" class="line-j" />
    <line x1="70" y1="75" x2="82" y2="50" class="line-k" />
  </svg>

  {featuredSpeakers.map(speaker => {
    const pos = positions[speaker.slug] || { top: '50%', left: '50%', size: '80px' };
    return (
      <div 
        class="speaker-node" 
        style={`top: ${pos.top}; left: ${pos.left}; --size: ${pos.size}; --delay: ${Math.random() * 2}s;`}
      >
        <div class="node-image-wrap">
          {speaker.image ? (
            <img src={resolvePublicPath(speaker.image)} alt={speaker.name} />
          ) : (
            <span class="node-placeholder">{speaker.name.charAt(0)}</span>
          )}
        </div>
        <span class="node-name">{speaker.name.split(' ').pop()}</span>
      </div>
    );
  })}
</div>

<style>
  .speaker-network {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    overflow: hidden;
    background: radial-gradient(circle at center, rgba(53, 95, 138, 0.1), transparent 70%);
  }

  .network-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .network-lines line {
    stroke: var(--accent);
    stroke-width: 0.15;
    stroke-opacity: 0.25;
    stroke-dasharray: 0.5 1;
    animation: dash 20s linear infinite;
  }

  @keyframes dash {
    to {
      stroke-dashoffset: -20;
    }
  }

  .speaker-node {
    position: absolute;
    width: var(--size);
    height: var(--size);
    transform: translate(-50%, -50%);
    z-index: 1;
    animation: float 6s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes float {
    0%, 100% { transform: translate(-50%, -52%); }
    50% { transform: translate(-50%, -48%); }
  }

  .node-image-wrap {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid #fff;
    box-shadow: 0 8px 24px rgba(20, 32, 51, 0.15);
    background: var(--surface-strong);
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .speaker-node:hover .node-image-wrap {
    transform: scale(1.1);
    box-shadow: 0 12px 32px rgba(255, 98, 40, 0.25);
    border-color: var(--accent);
  }

  .node-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .node-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    color: var(--accent);
    background: var(--accent-soft);
  }

  .node-name {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 0.5rem;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    background: rgba(255, 255, 255, 0.8);
    padding: 2px 6px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0.8;
  }

  @media (max-width: 600px) {
    .speaker-node {
      --size: 60px !important;
    }
    .node-name {
      display: none;
    }
  }
</style>
