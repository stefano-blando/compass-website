---
import { buildLocalizedPath, getLabels, getSiteIdentity, siteConfig } from '../../lib/site';
import type { Locale } from '../../data/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const labels = getLabels(locale);
const identity = getSiteIdentity(locale);
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <p class="site-footer__eyebrow">COMPASS</p>
      <p>{identity.fullTitle}</p>
      <p>{siteConfig.eventDate}</p>
      <p>{siteConfig.venue}</p>
    </div>

    <div>
      <p class="site-footer__eyebrow">{locale === 'it' ? 'Navigazione' : 'Navigation'}</p>
      <ul>
        <li><a href={buildLocalizedPath(locale)}>{labels.home}</a></li>
        <li><a href={buildLocalizedPath(locale, 'programme')}>{labels.programme}</a></li>
        <li><a href={buildLocalizedPath(locale, 'speakers')}>{labels.speakers}</a></li>
        <li><a href={buildLocalizedPath(locale, 'registration')}>{labels.registration}</a></li>
      </ul>
    </div>

    <div>
      <p class="site-footer__eyebrow">{locale === 'it' ? 'Istituzioni' : 'Institutions'}</p>
      <div class="site-footer__logos">
        <img src="/images/logos/sssa-color.png" alt="Scuola Superiore Sant’Anna" class="footer-logo" />
        <img src="/images/logos/unipi-white.png" alt="Università di Pisa" class="footer-logo" />
        <img src="/images/logos/ai_society_logo.png" alt="AI Society" class="footer-logo footer-logo--ai" />
      </div>
      <p>
        <a href={siteConfig.registrationUrl} target="_blank" rel="noreferrer">
          {locale === 'it' ? 'Modulo di registrazione esterno' : 'External registration form'}
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer__logos {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .footer-logo {
    height: 38px;
    width: auto;
    object-fit: contain;
  }
  .footer-logo--ai {
    height: 45px;
  }
</style>
