---
import ProgrammeTimeline from '../../../components/programme/ProgrammeTimeline.astro';
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getProgrammeSessions, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const copy = {
  en: {
    title: 'Programme',
    intro: 'Follow the workshop from the opening keynote through the AI methods panel and the final social dinner. Each talk links to a dedicated abstract page.',
    section: 'In this schedule',
    cards: [
      'Chronological session blocks with localized titles and descriptions.',
      'Talk entries connected to shared speaker and session data.',
      'A stable agenda structure ready for later expansion into speaker detail pages.',
    ],
    description: 'Full workshop programme with sessions, talk links, and shared agenda metadata.',
  },
  it: {
    title: 'Programma',
    intro: 'Segui il workshop dall’apertura keynote al panel sui metodi di AI fino alla cena sociale finale. Ogni intervento collega a una pagina con abstract dedicato.',
    section: 'In questo programma',
    cards: [
      'Blocchi cronologici con titoli e descrizioni localizzati.',
      'Interventi collegati ai dati condivisi di relatori e sessioni.',
      'Una struttura di agenda stabile pronta a espandersi senza anticipare le pagine speaker di dettaglio.',
    ],
    description: 'Programma completo del workshop con sessioni, link agli interventi e metadati condivisi dell’agenda.',
  },
}[locale];
const sessions = getProgrammeSessions();
---

<Layout locale={locale} title={`${copy.title} | COMPASS`} description={copy.description}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="container programme-page__timeline">
      <ProgrammeTimeline locale={locale} sessions={sessions} />
    </section>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .programme-page__timeline {
    margin-top: 1.5rem;
  }
</style>
