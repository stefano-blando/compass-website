---
import ProgrammeTimeline from '../../../components/programme/ProgrammeTimeline.astro';
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, getProgrammeSessions, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'programme');
const copy = {
  en: {
    title: 'Programme',
    intro: 'This seeded agenda shows the current opening keynote, AI methods panel, and social dinner entries already connected to shared session and talk data.',
    section: 'Current seeded agenda',
    cards: [
      'Chronological session blocks for the entries currently seeded in the data layer.',
      'Talk links with localized abstracts for the talks already published on the site.',
      'A stable agenda structure that can expand as additional sessions are confirmed.',
    ],
  },
  it: {
    title: 'Programma',
    intro: 'Questa agenda seed mostra le voci attualmente pubblicate: keynote di apertura, panel sui metodi di AI e cena sociale, tutte collegate ai dati condivisi di sessioni e interventi.',
    section: 'Agenda seed attuale',
    cards: [
      'Blocchi cronologici per le voci attualmente seminate nel data layer.',
      'Link agli abstract localizzati per gli interventi gia pubblicati sul sito.',
      'Una struttura stabile che puo espandersi quando saranno confermate altre sessioni.',
    ],
  },
}[locale];
const sessions = getProgrammeSessions();
---

<Layout locale={locale} title={pageMeta.title} description={pageMeta.description}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="container programme-page__timeline">
      <ProgrammeTimeline locale={locale} sessions={sessions} />
    </section>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .programme-page__timeline {
    margin-top: 1.5rem;
  }
</style>
