---
import ProgrammeTimeline from '../../../components/programme/ProgrammeTimeline.astro';
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, getProgrammeSessions, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'programme');
const copy = {
  en: {
    title: 'Programme',
    intro:
      'The current working agenda reflects the latest public lineup for 18 May 2026 in Aula 3 at Scuola Superiore Sant’Anna.',
    section: 'Current working agenda',
    cards: [
      'Chronological session blocks cover the full day from opening remarks to closing remarks.',
      'Panel lineups keep the named speakers currently published and leave unresolved rows explicitly marked TBD.',
      'Descriptions stay compact so the page remains readable while the agenda continues to evolve.',
    ],
  },
  it: {
    title: 'Programma',
    intro:
      'L agenda di lavoro attuale riflette la line-up pubblica piu recente per il 18 maggio 2026 in Aula 3 alla Scuola Superiore Sant’Anna.',
    section: 'Agenda in lavorazione',
    cards: [
      'I blocchi cronologici coprono l intera giornata dai saluti iniziali alla chiusura.',
      'Le scalette dei panel mantengono i relatori oggi pubblicati e lasciano i posti ancora aperti esplicitamente marcati TBD.',
      'Le descrizioni restano compatte per mantenere la pagina leggibile mentre l agenda continua a evolvere.',
    ],
  },
}[locale];
const sessions = getProgrammeSessions();
---

<Layout locale={locale} title={pageMeta.title} description={pageMeta.description}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="container programme-page__timeline">
      <ProgrammeTimeline locale={locale} sessions={sessions} />
    </section>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .programme-page__timeline {
    margin-top: 1.5rem;
  }
</style>
