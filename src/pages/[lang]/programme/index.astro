---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'programme');
const copy = {
  en: {
    title: 'Programme',
    intro: 'This route shell will become the structured programme page with sessions, talks, and timing.',
    section: 'What lands here next',
    cards: [
      'A full chronology of keynote sessions, thematic panels, and breaks.',
      'Links to speaker profiles and talk metadata sourced from the typed data layer.',
      'A layout designed to support both English and Italian programme views.',
    ],
  },
  it: {
    title: 'Programma',
    intro: 'Questa shell ospitera il programma strutturato con sessioni, interventi e orari.',
    section: 'Cosa arrivera qui',
    cards: [
      'Una cronologia completa di keynote, panel tematici e pause.',
      'Collegamenti ai profili speaker e ai metadati degli interventi dal data layer tipizzato.',
      'Un layout pensato per supportare il programma in inglese e in italiano.',
    ],
  },
}[locale];
---

<Layout locale={locale} title={pageMeta.title} description={pageMeta.description}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
