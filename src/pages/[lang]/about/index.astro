---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const copy = {
  en: {
    title: 'About',
    intro: 'This route shell frames the workshop mission and creates room for the final positioning copy.',
    section: 'Scope in this phase',
    cards: [
      'A concise explanation of the workshop theme and disciplinary intersection.',
      'A clear shell for bilingual copy on goals, audience, and expected outcomes.',
      'A bridge between the landing page and the detailed programme.',
    ],
  },
  it: {
    title: 'About',
    intro: 'Questa shell inquadra la missione del workshop e prepara lo spazio per il posizionamento finale.',
    section: 'Ambito di questa fase',
    cards: [
      'Una spiegazione sintetica del tema del workshop e dell incrocio disciplinare.',
      'Una shell chiara per il copy bilingue su obiettivi, pubblico e risultati attesi.',
      'Un collegamento tra homepage e programma dettagliato.',
    ],
  },
}[locale];
---

<Layout locale={locale} title={`${copy.title} | COMPASS`} description={copy.intro}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
