---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { buildLocalizedPath, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const publication = {
  en: {
    title: 'Abstracts',
    description: 'Future publication page for COMPASS abstracts and workshop materials after the event.',
    eyebrow: 'Post-event publication',
    intro:
      'This page is reserved for the abstract collection that will be published after the workshop. It keeps the public structure ready while the final materials are still being gathered.',
    cards: [
      {
        title: 'What will be published',
        body: 'Each talk can later appear here with title, speaker, affiliation, and the final approved abstract.',
      },
      {
        title: 'When it goes live',
        body: 'We keep this section offline in practice until the event has concluded and the submitted texts have been checked.',
      },
      {
        title: 'What may be added later',
        body: 'Slides, links, and other workshop materials can be attached here once contributors approve publication.',
      },
    ],
    cta: 'Prepare abstract submission',
  },
  it: {
    title: 'Abstracts',
    description: 'Pagina futura per la pubblicazione degli abstract e dei materiali del workshop COMPASS dopo l evento.',
    eyebrow: 'Pubblicazione post-evento',
    intro:
      'Questa pagina e riservata alla raccolta di abstract che verra pubblicata dopo il workshop. Tiene pronta la struttura pubblica mentre i materiali finali vengono ancora raccolti.',
    cards: [
      {
        title: 'Cosa verra pubblicato',
        body: 'Ogni talk potra comparire qui con titolo, relatore, affiliazione e abstract finale approvato.',
      },
      {
        title: 'Quando andra online',
        body: 'Teniamo questa sezione pronta, ma la apriamo davvero solo dopo l evento e dopo il controllo dei testi inviati.',
      },
      {
        title: 'Cosa potra essere aggiunto dopo',
        body: 'Slide, link e altri materiali del workshop potranno essere agganciati qui una volta approvati dai contributori.',
      },
    ],
    cta: 'Prepara l invio abstract',
  },
}[locale];
---

<Layout locale={locale} title={`${publication.title} | COMPASS`} description={publication.description}>
  <Header locale={locale} />
  <main class="abstracts-page">
    <section class="abstracts-page__hero">
      <div class="container abstracts-page__hero-shell">
        <div class="abstracts-page__copy">
          <p class="eyebrow">{publication.eyebrow}</p>
          <h1>{publication.title}</h1>
          <p class="abstracts-page__intro">{publication.intro}</p>
        </div>

        <aside class="abstracts-page__media" aria-label={publication.title}>
          <div class="abstracts-page__media-frame">
            <span class="abstracts-page__badge">{publication.title}</span>
            <div class="abstracts-page__stack" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="container abstracts-page__grid">
      {publication.cards.map((card) => (
        <article class="abstracts-page__card">
          <h2>{card.title}</h2>
          <p>{card.body}</p>
        </article>
      ))}
    </section>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .abstracts-page {
    padding: 2rem 0 5rem;
  }

  .abstracts-page__hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: 1.5rem;
  }

  .abstracts-page__copy,
  .abstracts-page__media,
  .abstracts-page__card {
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.68);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .abstracts-page__copy,
  .abstracts-page__card {
    padding: clamp(2rem, 4vw, 3rem);
    background: rgba(255, 253, 249, 0.86);
    backdrop-filter: blur(18px);
  }

  .abstracts-page__copy h1 {
    margin: 0.35rem 0 0.9rem;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.94;
  }

  .abstracts-page__intro,
  .abstracts-page__card p {
    color: var(--ink-soft);
  }

  .abstracts-page__media {
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.14), transparent 24%),
      linear-gradient(180deg, rgba(19, 35, 53, 0.96), rgba(63, 89, 120, 0.84));
    min-height: 18rem;
  }

  .abstracts-page__media-frame {
    height: 100%;
    padding: 1.35rem;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .abstracts-page__badge {
    display: inline-flex;
    width: fit-content;
    padding: 0.42rem 0.68rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: rgba(255, 250, 245, 0.92);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .abstracts-page__stack {
    display: grid;
    gap: 0.8rem;
  }

  .abstracts-page__stack span {
    display: block;
    height: 4.6rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.12);
  }

  .abstracts-page__grid {
    display: grid;
    gap: 1.3rem;
    margin-top: 1.6rem;
  }

  .abstracts-page__card h2 {
    margin: 0 0 0.7rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.96;
  }

  @media (max-width: 960px) {
    .abstracts-page__hero-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .abstracts-page {
      padding-top: 1.2rem;
    }

    .abstracts-page__copy,
    .abstracts-page__card {
      padding: 1.4rem;
      border-radius: 24px;
    }

    .abstracts-page__media {
      min-height: 16rem;
      border-radius: 24px;
    }
  }
</style>
