---
import { buildLocalizedPath } from '../../../lib/site';
import RichContentPage from '../../../components/site/RichContentPage.astro';
import SpeakerCard from '../../../components/site/SpeakerCard.astro';
import SpeakerNetworkHero from '../../../components/site/SpeakerNetworkHero.astro';
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import { speakers } from '../../../data/speakers';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, getRichPageContent, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'speakers');
const content = getRichPageContent(locale, 'speakers');

const keynotes = speakers.filter(s => s.type.includes('keynote'));
const organizers = speakers.filter(s => s.type.includes('chair') || s.type.includes('organizer'));
const contributors = speakers.filter(s => s.type.includes('panelist') && !s.type.includes('chair'));

const t = {
  en: {
    keynotes: 'Keynote Speakers',
    organizers: 'Organizers & Track Chairs',
    contributors: 'Panel Contributors',
  },
  it: {
    keynotes: 'Relatori Keynote',
    organizers: 'Organizzatori e Chair delle Track',
    contributors: 'Contributori dei Panel',
  }
}[locale];
---

<Layout locale={locale} title={pageMeta.title} description={pageMeta.description}>
  <Header locale={locale} />
  <main class="speakers-page">
    <section class="speakers-hero">
      <div class="container speakers-hero__inner">
        <div class="speakers-hero__copy">
          <p class="eyebrow">{content.hero.eyebrow}</p>
          <h1 class="display-serif">{content.hero.title}</h1>
          <p class="intro-text">{content.hero.intro}</p>
        </div>
        <div class="speakers-hero__visual">
          <SpeakerNetworkHero />
        </div>
      </div>
    </section>
    
    <div class="container speaker-directory">
      <section class="directory-section">
        <h2 class="section-kicker">{t.keynotes}</h2>
        <div class="speaker-grid">
          {keynotes.map(speaker => <SpeakerCard speaker={speaker} locale={locale} />)}
        </div>
      </section>

      <section class="directory-section">
        <h2 class="section-kicker">{t.organizers}</h2>
        <div class="speaker-grid">
          {organizers.map(speaker => <SpeakerCard speaker={speaker} locale={locale} />)}
        </div>
      </section>

      <section class="directory-section">
        <h2 class="section-kicker">{t.contributors}</h2>
        <div class="speaker-grid">
          {contributors.map(speaker => <SpeakerCard speaker={speaker} locale={locale} />)}
        </div>
      </section>
    </div>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .speakers-page {
    padding: 2rem 0 5rem;
  }

  .speakers-hero {
    margin-bottom: 4rem;
  }

  .speakers-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: 2rem;
    align-items: stretch;
  }

  .speakers-hero__copy,
  .speakers-hero__visual {
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.68);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .speakers-hero__copy {
    background: rgba(255, 253, 249, 0.84);
    backdrop-filter: blur(18px);
    padding: clamp(2rem, 4vw, 3.4rem);
  }

  .speakers-hero__copy h1 {
    margin: 0.4rem 0 0.9rem;
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.94;
    color: var(--ink);
  }

  .intro-text {
    font-size: 1.1rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .speakers-hero__visual {
    background: var(--ink);
    min-height: 400px;
  }

  .speaker-directory {
    display: grid;
    gap: 5rem;
  }

  .directory-section {
    display: grid;
    gap: 2rem;
  }

  .speaker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 960px) {
    .speakers-hero__inner {
      grid-template-columns: 1fr;
    }
    
    .speakers-hero__visual {
      min-height: 320px;
    }
  }

  @media (max-width: 600px) {
    .speaker-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
