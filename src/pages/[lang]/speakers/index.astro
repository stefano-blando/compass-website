---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'speakers');
const copy = {
  en: {
    title: 'Speakers',
    intro: 'This route shell will become the speaker listing with affiliations, roles, and talk links.',
    section: 'Planned content',
    cards: [
      'Localized speaker cards connected to typed speaker records.',
      'Clear links from each speaker to their talks and session appearances.',
      'A stable shell for later detail pages and filters.',
    ],
  },
  it: {
    title: 'Relatori',
    intro: 'Questa shell diventera la pagina speaker con affiliazioni, ruoli e collegamenti agli interventi.',
    section: 'Contenuti previsti',
    cards: [
      'Card localizzate collegate ai record tipizzati degli speaker.',
      'Link chiari da ogni speaker ai propri talk e alle sessioni di riferimento.',
      'Una base stabile per future pagine di dettaglio e filtri.',
    ],
  },
}[locale];
---

<Layout locale={locale} title={pageMeta.title} description={pageMeta.description}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
