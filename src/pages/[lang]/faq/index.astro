---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const copy = {
  en: {
    title: 'FAQ',
    intro: 'This route shell reserves space for practical workshop questions while the full content is assembled.',
    section: 'Likely topics',
    cards: [
      'Registration timing, attendance expectations, and participation format.',
      'Venue access, travel, and local logistics in Pisa.',
      'Language, materials, and follow-up communication for attendees.',
    ],
  },
  it: {
    title: 'FAQ',
    intro: 'Questa shell riserva spazio alle domande pratiche sul workshop mentre il contenuto finale viene completato.',
    section: 'Temi previsti',
    cards: [
      'Tempistiche di registrazione, aspettative di partecipazione e formato dell evento.',
      'Accesso alla sede, viaggio e logistica locale a Pisa.',
      'Lingua, materiali e comunicazioni successive per i partecipanti.',
    ],
  },
}[locale];
---

<Layout locale={locale} title={`${copy.title} | COMPASS`} description={copy.intro}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
