---
import RichContentPage from '../../../components/site/RichContentPage.astro';
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import SpeakerCard from '../../../components/site/SpeakerCard.astro';
import { speakers } from '../../../data/speakers';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, getRichPageContent, locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'organizers');
const content = getRichPageContent(locale, 'organizers');

const institutional = speakers.filter(s => s.type.includes('institutional'));
const organizers = speakers.filter(s => s.type.includes('organizer'));

const labels = {
  en: {
    committeeTitle: 'Scientific Committee',
    committeeIntro: 'Senior academic faculty and institutional representatives providing oversight and scientific framing.',
    teamTitle: 'Organizing Team',
    teamIntro: 'Meet the doctoral researchers coordinating the COMPASS workshop operations and panel tracks.'
  },
  it: {
    committeeTitle: 'Comitato Scientifico',
    committeeIntro: 'Docenti senior e rappresentanti istituzionali che curano la visione scientifica e il coordinamento.',
    teamTitle: 'Team Organizzativo',
    teamIntro: 'I ricercatori dottorali che coordinano le operazioni e le sessioni del workshop COMPASS.'
  }
}[locale];
---

<Layout locale={locale} title={pageMeta.title} description={pageMeta.description}>
  <Header locale={locale} />
  <main>
    <RichContentPage locale={locale} page="organizers" content={content} />
    
    <section class="organizers-team">
      <div class="container">
        <div class="organizers-team__header">
          <p class="eyebrow">{labels.committeeTitle}</p>
          <h2>{labels.committeeTitle}</h2>
          <p>{labels.committeeIntro}</p>
        </div>
        <div class="organizers-team__grid organizers-team__grid--institutional">
          {institutional.map(member => (
            <SpeakerCard speaker={member} locale={locale} />
          ))}
        </div>

        <div class="organizers-team__header" style="margin-top: 6rem;">
          <p class="eyebrow">{labels.teamTitle}</p>
          <h2>{labels.teamTitle}</h2>
          <p>{labels.teamIntro}</p>
        </div>
        <div class="organizers-team__grid">
          {organizers.map(organizer => (
            <SpeakerCard speaker={organizer} locale={locale} />
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .organizers-team {
    padding: 4rem 0 8rem;
    background: var(--surface-muted);
  }

  .organizers-team__header {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 3.5rem;
  }

  .organizers-team__header h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin: 0.5rem 0 1rem;
    line-height: 1;
  }

  .organizers-team__header p {
    color: var(--ink-soft);
    font-size: 1.15rem;
    line-height: 1.5;
  }

  .organizers-team__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .organizers-team__grid--institutional {
    justify-content: center;
    display: flex;
    flex-wrap: wrap;
  }

  .organizers-team__grid--institutional > :global(*) {
    flex: 0 1 320px;
  }

  @media (max-width: 720px) {
    .organizers-team {
      padding: 3rem 0 4rem;
    }
    
    .organizers-team__grid {
      grid-template-columns: 1fr;
    }

    .organizers-team__grid--institutional {
      display: grid;
    }
  }
</style>
