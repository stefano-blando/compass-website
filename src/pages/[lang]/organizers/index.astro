---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { locales } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const copy = {
  en: {
    title: 'Organizers',
    intro: 'This route shell will host the organizing committee and institutional context for the workshop.',
    section: 'Next additions',
    cards: [
      'Organizer profiles connected to the shared speaker and role data.',
      'Institutional references and hosting acknowledgements.',
      'A stable destination for contacts and operational ownership.',
    ],
  },
  it: {
    title: 'Organizzazione',
    intro: 'Questa shell ospitera il comitato organizzatore e il contesto istituzionale del workshop.',
    section: 'Prossimi inserimenti',
    cards: [
      'Profili degli organizzatori collegati ai dati condivisi di speaker e ruoli.',
      'Riferimenti istituzionali e acknowledgements di hosting.',
      'Una destinazione stabile per contatti e responsabilita operative.',
    ],
  },
}[locale];
---

<Layout locale={locale} title={`${copy.title} | COMPASS`} description={copy.intro}>
  <Header locale={locale} />
  <main class="page-shell">
    <section class="page-hero container">
      <div class="page-hero__content">
        <p class="eyebrow">COMPASS</p>
        <h1>{copy.title}</h1>
        <p class="page-lead">{copy.intro}</p>
      </div>
      <aside class="page-hero__meta">
        <p class="page-meta__label">{copy.section}</p>
        <ul class="page-meta__list">
          {copy.cards.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
