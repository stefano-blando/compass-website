---
import Footer from '../../../components/site/Footer.astro';
import Header from '../../../components/site/Header.astro';
import type { Locale } from '../../../data/types';
import Layout from '../../../layouts/Layout.astro';
import { getPageMetadata, locales, buildLocalizedPath } from '../../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'registration');

const t = {
  en: {
    title: 'Registration Successful',
    message: 'Thank you for registering for COMPASS 2026. We have received your details and look forward to seeing you in Pisa.',
    back: 'Back to Home',
    calendar: 'Add to Calendar',
  },
  it: {
    title: 'Registrazione completata',
    message: 'Grazie per esserti registrato a COMPASS 2026. Abbiamo ricevuto i tuoi dati e ti aspettiamo a Pisa.',
    back: 'Torna alla Home',
    calendar: 'Aggiungi al calendario',
  }
}[locale];
---

<Layout locale={locale} title={`${t.title} | COMPASS`} description={pageMeta.description}>
  <Header locale={locale} />
  <main class="success-page">
    <div class="container success-page__shell">
      <div class="success-card">
        <div class="success-card__icon">✓</div>
        <h1>{t.title}</h1>
        <p>{t.message}</p>
        
        <div class="success-card__actions">
          <a href={buildLocalizedPath(locale, 'home')} class="btn-primary">{t.back}</a>
          <a 
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=COMPASS+Workshop+2026&dates=20260518T073000Z/20260518T161500Z&details=Complexity,+Markets,+Policy,+and+AI+in+Social+Systems+Workshop&location=Scuola+Superiore+Sant’Anna,+Pisa" 
            target="_blank" 
            class="btn-secondary"
          >
            {t.calendar}
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .success-page {
    padding: 6rem 0 10rem;
    background: var(--surface-muted);
    min-height: 70vh;
    display: grid;
    place-items: center;
  }

  .success-card {
    background: var(--surface);
    padding: clamp(2rem, 8vw, 5rem);
    border-radius: 40px;
    box-shadow: var(--shadow-strong);
    text-align: center;
    max-width: 40rem;
    border: 1px solid rgba(255, 255, 255, 0.6);
  }

  .success-card__icon {
    width: 5rem;
    height: 5rem;
    background: var(--accent);
    color: white;
    font-size: 2.5rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    margin: 0 auto 2rem;
  }

  .success-card h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1.5rem;
    color: var(--ink);
  }

  .success-card p {
    font-size: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  .success-card__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .success-card__actions > * {
      width: 100%;
    }
  }
</style>