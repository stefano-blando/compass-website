---
import DarkStageSection from '../../components/home/DarkStageSection.astro';
import FeaturedSpeakersSection from '../../components/home/FeaturedSpeakersSection.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import HomeNetworkBackground from '../../components/home/HomeNetworkBackground.astro';
import MediaShowcaseSection from '../../components/home/MediaShowcaseSection.astro';
import ProgrammePreviewSection from '../../components/home/ProgrammePreviewSection.astro';
import RegistrationCtaSection from '../../components/home/RegistrationCtaSection.astro';
import VenuePreviewSection from '../../components/home/VenuePreviewSection.astro';
import WhyCompassSection from '../../components/home/WhyCompassSection.astro';
import Footer from '../../components/site/Footer.astro';
import Header from '../../components/site/Header.astro';
import type { Locale } from '../../data/types';
import Layout from '../../layouts/Layout.astro';
import { getPageMetadata, locales } from '../../lib/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const pageMeta = getPageMetadata(locale, 'home');
---

<Layout
  locale={locale}
  title={pageMeta.title}
  description={pageMeta.description}
>
  <script is:inline>
    if ('IntersectionObserver' in window) {
      document.documentElement.dataset.js = 'true';
    }
  </script>

  <Header locale={locale} />

  <main class="home-shell" data-home-parallax>
    <HomeNetworkBackground />
    <HeroSection locale={locale} />
    <DarkStageSection locale={locale} />
    <ProgrammePreviewSection locale={locale} />
    <FeaturedSpeakersSection locale={locale} />
    <WhyCompassSection locale={locale} />
    <MediaShowcaseSection locale={locale} />
    <VenuePreviewSection locale={locale} />
    <RegistrationCtaSection locale={locale} />
  </main>

  <Footer locale={locale} />

  <script is:inline>
    (() => {
      if (!('IntersectionObserver' in window)) {
        return;
      }

      const parallaxRoot = document.querySelector('[data-home-parallax]');
      const sections = Array.from(document.querySelectorAll('[data-home-reveal]'));
      if (!sections.length) {
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) {
              continue;
            }

            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        },
        { threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
      );

      sections.forEach((section) => observer.observe(section));

      if (!parallaxRoot) {
        return;
      }

      const parallaxNodes = Array.from(parallaxRoot.querySelectorAll('[data-scroll-shift]'));
      if (!parallaxNodes.length) {
        return;
      }

      const updateParallax = () => {
        const viewportHeight = window.innerHeight || 1;

        sections.forEach((section) => {
          const rect = section.getBoundingClientRect();
          const progress = Math.max(0, Math.min(1, 1 - rect.top / viewportHeight));
          section.style.setProperty('--section-progress', progress.toFixed(3));
        });

        parallaxNodes.forEach((node) => {
          const speed = Number(node.getAttribute('data-scroll-speed') ?? '24');
          const direction = Number(node.getAttribute('data-scroll-direction') ?? '1');
          const rect = node.getBoundingClientRect();
          const progress = ((rect.top + rect.height * 0.5) / viewportHeight) - 0.5;
          const offset = progress * speed * direction;
          node.style.setProperty('--scroll-shift', `${offset.toFixed(2)}px`);
        });
      };

      updateParallax();
      window.addEventListener('scroll', updateParallax, { passive: true });
      window.addEventListener('resize', updateParallax);
    })();
  </script>
</Layout>

<style>
  .home-shell {
    position: relative;
    isolation: isolate;
    padding-bottom: 4rem;
  }

  .home-shell > :not([data-home-network-bg]) {
    position: relative;
    z-index: 1;
  }
</style>
